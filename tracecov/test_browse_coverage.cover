    1: def _add_src(store, key, stype, title, config=None, update_cmd="x", delete_cmd="y"):
           """Add source and return its actual source_dir path."""
 1376:     store.add_collection_source(
  688:         key_name=key, source_type=stype, title=title,
  688:         config=config or {},
  688:         update_command=update_cmd, delete_command=delete_cmd,
           )
  688:     sources = store.list_collection_sources(key_name=key, source_type=stype)
 1376:     src = [s for s in sources if s.get("title") == title][0]
  688:     d = store.source_dir(src)
  688:     d.mkdir(parents=True, exist_ok=True)
  688:     return d, src
       
       
