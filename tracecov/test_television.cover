       # ── Keys ─────────────────────────────────────────────────────────────────
       
    2: class TestKeysTelevision:
    1:     def test_format_keys_television_basic(self):
    1:         result = format_keys_television(["research", "work"])
    1:         assert result == "research\nwork"
       
    1:     def test_format_keys_television_empty(self):
    1:         assert format_keys_television([]) == ""
       
    1:     def test_format_keys_preview_basic(self):
    1:         result = format_keys_preview(["research", "work"], "research")
    1:         assert "# research" in result
    1:         assert "know list sources --key research" in result
    1:         assert "know sync --key research" in result
    1:         assert "know export --key research" in result
       
    1:     def test_format_keys_preview_no_selection(self):
    1:         result = format_keys_preview(["research"], None)
    1:         assert "# research" in result
       
    1:     def test_format_keys_preview_empty(self):
    1:         result = format_keys_preview([], None)
    1:         assert "No key matched" in result
       
    1:     def test_format_keys_preview_nonexistent_falls_back(self):
    1:         result = format_keys_preview(["alpha"], "nonexistent")
    1:         assert "# alpha" in result
       
       
       # ── Sources ──────────────────────────────────────────────────────────────
       
    2: class TestSourcesTelevision:
