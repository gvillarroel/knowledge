       # ── Helpers ──────────────────────────────────────────────────────────────
       
    2: class TestHelpers:
    1:     def test_resolve_selection_empty(self):
    1:         assert _resolve_selection([], "x") is None
       
    1:     def test_resolve_selection_none(self):
    1:         assert _resolve_selection(["a", "b"], None) == "a"
       
    1:     def test_resolve_selection_match(self):
    1:         assert _resolve_selection(["a", "b"], "b") == "b"
       
    1:     def test_resolve_selection_no_match_fallback(self):
    1:         assert _resolve_selection(["a", "b"], "c") == "a"
       
    1:     def test_strip_html_tags(self):
    1:         assert _strip_html_tags("<b>bold</b> text") == "bold text"
    1:         assert _strip_html_tags("no tags") == "no tags"
    1:         assert _strip_html_tags("") == ""
       
       
       # ── CLI integration with --format television ─────────────────────────────
       
    2: class TestCLITelevisionIntegration:
    1:     """Test that commands accept --format television flags via the parser."""
       
    1:     def test_list_keys_television(self, tmp_path):
    1:         from knowledge.cli import main
    1:         store = tmp_path / "store"
               # Create a key
    1:         main(["--store", str(store), "add", "key", "mykey"])
               # List keys in television format
    1:         rc = main(["--store", str(store), "list", "keys", "--format", "television"])
    1:         assert rc == 0
       
    1:     def test_list_keys_television_preview(self, tmp_path):
    1:         from knowledge.cli import main
    1:         store = tmp_path / "store"
    1:         main(["--store", str(store), "add", "key", "mykey"])
    1:         rc = main(["--store", str(store), "list", "keys", "--format", "television-preview", "--entry", "mykey"])
    1:         assert rc == 0
       
    1:     def test_list_sources_television(self, tmp_path):
    1:         from knowledge.cli import main
    1:         store = tmp_path / "store"
    1:         main(["--store", str(store), "add", "key", "k1"])
    1:         rc = main(["--store", str(store), "list", "sources", "--format", "television"])
    1:         assert rc == 0
       
    1:     def test_list_sources_television_preview(self, tmp_path):
    1:         from knowledge.cli import main
    1:         store = tmp_path / "store"
    1:         main(["--store", str(store), "add", "key", "k1"])
    1:         main(["--store", str(store), "add", "arxiv", "https://arxiv.org/abs/1706.03762", "--key", "k1"])
    1:         rc = main(["--store", str(store), "list", "sources", "--format", "television-preview"])
    1:         assert rc == 0
       
    1:     def test_list_credentials_does_not_accept_television_flags(self, tmp_path):
    1:         from knowledge.cli import main
    1:         store = tmp_path / "store"
    1:         main(["--store", str(store), "init"])
    1:         main(["--store", str(store), "set", "credential", "tok", "val"])
    2:         with pytest.raises(SystemExit) as excinfo:
    1:             main(["--store", str(store), "list", "credentials", "--format", "television"])
    1:         assert excinfo.value.code == 2
