    1:         assert "No source matched" in result
       
    1:     def test_find_source_by_id(self):
    1:         found = _find_source(self.SAMPLE_SOURCES, "jira-kan | jira | work | KAN")
    1:         assert found is not None
    1:         assert found["id"] == "jira-kan"
       
    1:     def test_find_source_fallback(self):
    1:         found = _find_source(self.SAMPLE_SOURCES, "nonexistent")
    1:         assert found is not None
    1:         assert found["id"] == "confluence-eng"
       
    1:     def test_find_source_empty(self):
    1:         assert _find_source([], "anything") is None
       
    1:     def test_format_sources_preview_with_markdown_body(self):
    1:         body = "# Introduction\n\nSome content here."
    2:         result = format_sources_preview(
    1:             self.SAMPLE_SOURCES,
    1:             "confluence-eng | confluence | research | ENG",
    1:             markdown_body=body,
               )
    1:         assert "# ENG" in result
    1:         assert "# Introduction" in result
    1:         assert "Some content here." in result
               # Should NOT contain metadata fields when body is present
    1:         assert "Source id:" not in result
    1:         assert "Type:" not in result
       
    1:     def test_format_sources_preview_none_body_falls_back(self):
    2:         result = format_sources_preview(
    1:             self.SAMPLE_SOURCES,
    1:             "confluence-eng | confluence | research | ENG",
    1:             markdown_body=None,
               )
               # Falls back to metadata view
    1:         assert "Source id:" in result
    1:         assert "confluence-eng" in result
       
    1:     def test_format_sources_preview_empty_body_falls_back(self):
    2:         result = format_sources_preview(
    1:             self.SAMPLE_SOURCES,
    1:             "confluence-eng | confluence | research | ENG",
    1:             markdown_body="",
               )
               # Empty string is falsy, falls back to metadata
    1:         assert "Source id:" in result
       
       
