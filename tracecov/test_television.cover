               )
    1:         assert "# ENG" in result
    1:         assert "confluence-eng" in result
    1:         assert "know sync confluence" in result
    1:         assert "space: ENG" in result
       
    1:     def test_format_sources_preview_no_selection(self):
    1:         result = format_sources_preview(self.SAMPLE_SOURCES, None)
    1:         assert "# ENG" in result
       
    1:     def test_format_sources_preview_empty(self):
