       # ── Helpers ──────────────────────────────────────────────────────────────
       
    2: class TestExtendedHelpers:
    1:     def test_extract_arxiv_id(self):
    1:         assert _extract_arxiv_id("https://arxiv.org/abs/2301.00001") == "2301.00001"
    1:         assert _extract_arxiv_id("https://arxiv.org/pdf/2301.00001v2") == "2301.00001v2"
    1:         assert _extract_arxiv_id("not-an-id") == "not-an-id"
       
    1:     def test_repo_short_name(self):
    1:         assert _repo_short_name("https://github.com/owner/repo.git") == "owner/repo"
    1:         assert _repo_short_name("https://github.com/owner/repo") == "owner/repo"
       
    1:     def test_find_by_name(self):
    1:         items = [{"name": "alpha"}, {"name": "beta"}]
    1:         assert _find_by_name(items, None) == items[0]
    1:         assert _find_by_name(items, "beta")["name"] == "beta"
    1:         assert _find_by_name([], "x") is None
       
    1:     def test_find_by_field(self):
    1:         items = [{"type": "arxiv"}, {"type": "jira"}]
    1:         assert _find_by_field(items, "type", "jira")["type"] == "jira"
    1:         assert _find_by_field(items, "type", None) == items[0]
    1:         assert _find_by_field([], "type", "x") is None
       
    1:     def test_find_by_title(self):
    1:         items = [{"title": "Paper A"}, {"title": "Paper B"}]
    1:         assert _find_by_title(items, "Paper B")["title"] == "Paper B"
    1:         assert _find_by_title(items, None) == items[0]
       
    1:     def test_find_cmd(self):
    1:         cmds = [{"command": "know sync --key a"}, {"command": "know export --key b"}]
    1:         assert _find_cmd(cmds, "know export --key b")["command"] == "know export --key b"
    1:         assert _find_cmd(cmds, None) == cmds[0]
    1:         assert _find_cmd([], "x") is None
       
       
       # ── CLI parser integration ──────────────────────────────────────────────
       
    2: class TestExtendedCLIParsing:
    1:     def test_all_extended_browse_subcommands(self):
    1:         from knowledge.cli import build_parser
    1:         parser = build_parser()
   14:         for cmd in [
                   "by-key", "by-type", "papers", "repos", "repo-files",
                   "files", "recent", "stale", "unsynced", "timeline",
                   "commands", "stats", "crossref",
               ]:
   13:             args = parser.parse_args(["browse", cmd, "--format", "television"])
   13:             assert args.format == "television"
       
    1:     def test_key_sources_parse(self):
