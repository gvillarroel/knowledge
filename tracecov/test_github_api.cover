    2: class TestHeaders:
    1:     def test_bearer_token(self):
    1:         h = _headers("test-token")
    1:         assert h["Authorization"] == "Bearer test-token"
    1:         assert "application/vnd.github" in h["Accept"]
       
       
    2: class TestListUserRepos:
    2:     @patch("knowledge.sources.github_api.requests.get")
    2:     def test_returns_repos(self, mock_get):
    1:         mock_resp = MagicMock()
    1:         mock_resp.json.return_value = [{"full_name": "user/repo1"}, {"full_name": "user/repo2"}]
    1:         mock_resp.raise_for_status = MagicMock()
    1:         mock_get.return_value = mock_resp
       
    1:         repos = list_user_repos("tok")
    1:         assert len(repos) == 2
    1:         assert repos[0]["full_name"] == "user/repo1"
       
       
