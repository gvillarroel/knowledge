    1:              "created_at": "", "updated_at": "", "body": "", "labels": [],
    1:              "html_url": "", "comments": 0},
               ]
    1:         items = list_repo_activity("tok", "owner", "repo")
    1:         assert len(items) == 1
       
       
    2: class TestRenderIssueThread:
    2:     @patch("knowledge.sources.github_api.get_issue_comments")
    2:     def test_render_issue(self, mock_comments):
    1:         mock_comments.return_value = [
    1:             {"body": "Looks good", "user": {"login": "bob"}, "created_at": "2026-01-01"},
               ]
    1:         item = {
    1:             "kind": "issue", "number": 42, "title": "A Bug",
    1:             "body": "Steps to reproduce...", "user": "alice",
    1:             "created_at": "2026-01-01", "state": "open",
    1:             "labels": ["bug"], "url": "https://github.com/x/y/issues/42",
               }
    1:         md = render_issue_thread_markdown("tok", "owner", "repo", item)
    1:         assert "A Bug" in md
    1:         assert "#42" in md
    1:         assert "Steps to reproduce" in md
    1:         assert "Looks good" in md
    1:         assert "@bob" in md
       
    1:     def test_render_discussion(self):
    1:         item = {
    1:             "kind": "discussion", "number": 5, "title": "Question",
    1:             "body": "How do I...", "user": "carol",
    1:             "created_at": "2026-01-01", "state": "open",
    1:             "labels": [], "url": "https://github.com/x/y/discussions/5",
    2:             "_discussion_comments": [
    1:                 {"body": "Answer here", "author": {"login": "dave"}, "createdAt": "2026-01-02"},
                   ],
               }
    1:         md = render_issue_thread_markdown("tok", "owner", "repo", item)
    1:         assert "Discussion #5" in md
    1:         assert "Answer here" in md
    1:         assert "@dave" in md
       
    2:     @patch("knowledge.sources.github_api.get_issue_comments", side_effect=Exception("fail"))
    2:     def test_render_with_comment_failure(self, mock_comments):
    1:         item = {
    1:             "kind": "issue", "number": 1, "title": "Bug",
    1:             "body": "Desc", "user": "u", "created_at": "",
    1:             "state": "open", "labels": [], "url": "",
               }
    1:         md = render_issue_thread_markdown("tok", "o", "r", item)
    1:         assert "Could not load comments" in md
