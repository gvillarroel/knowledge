    2: class TestListRepoActivity:
    2:     @patch("knowledge.sources.github_api.list_repo_discussions")
    2:     @patch("knowledge.sources.github_api.list_repo_issues")
    2:     def test_unified_activity(self, mock_issues, mock_discussions):
    1:         mock_issues.return_value = [
    2:             {"number": 1, "title": "Bug", "state": "open", "user": {"login": "a"},
    1:              "created_at": "", "updated_at": "", "body": "", "labels": [],
    1:              "html_url": "", "comments": 0},
    2:             {"number": 2, "title": "PR Fix", "state": "open", "user": {"login": "b"},
    1:              "created_at": "", "updated_at": "", "body": "", "labels": [],
    1:              "html_url": "", "comments": 1, "pull_request": {"url": "..."}},
               ]
    1:         mock_discussions.return_value = [
    2:             {"number": 3, "title": "Q", "body": "", "url": "",
    1:              "createdAt": "", "updatedAt": "", "author": {"login": "c"},
    1:              "category": {"name": "Q&A"},
    1:              "comments": {"nodes": []}},
               ]
       
    1:         items = list_repo_activity("tok", "owner", "repo")
    1:         assert len(items) == 3
    4:         kinds = [i["kind"] for i in items]
    1:         assert "issue" in kinds
    1:         assert "pull_request" in kinds
    1:         assert "discussion" in kinds
       
    2:     @patch("knowledge.sources.github_api.list_repo_discussions", side_effect=Exception("no discussions"))
