    1:     def test_fetch_single_page_403_falls_back_to_proxy(self, tmp_path, monkeypatch):
    1:         import requests as req
    1:         store = make_store(tmp_path)
    1:         store.create_collection_key("k")
    2:         source = store.add_collection_source(
    1:             "k", "site", title="https://example.com",
    1:             config={"url": "https://example.com", "max_depth": 1, "max_pages": 1},
    1:             update_command="sync", delete_command="del",
               )
    1:         adapter = SiteSource(source, store)
       
    2:         class FakeErrorResp:
    1:             status_code = 403
    1:             text = ""
    1:             headers = {}
    1:             def raise_for_status(self):
    1:                 err = req.HTTPError(response=self)
    1:                 raise err
    1:             def json(self): return {}
       
    2:         class FakeProxyResp:
    1:             text = "Title: Proxy Page\n\nContent from proxy\n"
    1:             headers = {"Content-Type": "text/plain"}
    2:             def raise_for_status(self): pass
    1:             def json(self): return {}
       
    1:         call_count = [0]
    1:         def fake_get(*args, **kwargs):
    2:             call_count[0] += 1
    2:             if call_count[0] == 1:
    1:                 return FakeErrorResp()
    1:             return FakeProxyResp()
       
    1:         monkeypatch.setattr("knowledge.sources.crawl4ai_site.requests.get", fake_get)
    1:         result = adapter._fetch_single_page("https://example.com")
    1:         assert result["title"] == "Proxy Page"
    1:         assert result["metadata"]["fetched_via"] == "r.jina.ai"
       
