    2: class TestErrors:
    1:     def test_knowledge_error_is_exception(self):
    1:         assert issubclass(KnowledgeError, Exception)
       
    1:     def test_credential_not_found(self):
    1:         err = CredentialNotFoundError("$token")
    1:         assert err.reference == "$token"
    1:         assert "not found" in str(err)
       
    1:     def test_source_not_found(self):
    1:         err = SourceNotFoundError("docs", "src-1")
    1:         assert err.key_name == "docs"
    1:         assert err.source_id == "src-1"
    1:         assert "src-1" in str(err)
       
    1:     def test_key_already_exists(self):
    1:         err = KeyAlreadyExistsError("docs")
    1:         assert err.key_name == "docs"
    1:         assert "already exists" in str(err)
       
    1:     def test_source_already_exists(self):
    1:         err = SourceAlreadyExistsError("docs", "src-1")
    1:         assert err.key_name == "docs"
    1:         assert err.source_id == "src-1"
    1:         assert "already exists" in str(err)
       
    1:     def test_invalid_url(self):
    1:         err = InvalidURLError("ftp://x", reason="bad scheme")
    1:         assert err.url == "ftp://x"
    1:         assert "bad scheme" in str(err)
       
    1:     def test_invalid_url_default_reason(self):
    1:         err = InvalidURLError("bad")
    1:         assert "invalid URL" in str(err)
       
    1:     def test_sync_error(self):
    1:         err = SyncError("docs", "src-1", "timeout")
    1:         assert err.key_name == "docs"
    1:         assert err.source_id == "src-1"
    1:         assert "timeout" in str(err)
       
       
