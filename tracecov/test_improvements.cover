    1:     def test_clear_source_dir(self, tmp_path):
    1:         store = make_store(tmp_path)
    1:         store.create_collection_key("k")
    2:         source = store.add_collection_source(
    1:             "k", "arxiv", title="paper",
    1:             config={"url": "https://arxiv.org/abs/1"},
    1:             update_command="sync", delete_command="del",
               )
    1:         adapter = ConcreteAdapter(source, store)
               # Create some files
    1:         (adapter.raw_dir / "file.txt").write_text("hello", encoding="utf-8")
    1:         sub = adapter.raw_dir / "subdir"
    1:         sub.mkdir()
    1:         (sub / "inner.txt").write_text("inner", encoding="utf-8")
    1:         adapter.clear_source_dir()
               # Dir exists but is empty
    1:         assert adapter.raw_dir.exists()
    1:         assert list(adapter.raw_dir.iterdir()) == []
       
    1:     def test_clear_source_dir_when_not_exists(self, tmp_path):
    1:         store = make_store(tmp_path)
    1:         store.create_collection_key("k")
    2:         source = store.add_collection_source(
    1:             "k", "arxiv", title="paper",
    1:             config={"url": "https://arxiv.org/abs/1"},
    1:             update_command="sync", delete_command="del",
               )
    1:         adapter = ConcreteAdapter(source, store)
    1:         import shutil
    1:         if adapter.raw_dir.exists():
    1:             shutil.rmtree(adapter.raw_dir)
    1:         adapter.clear_source_dir()
    1:         assert adapter.raw_dir.exists()
       
    1:     def test_finalize_sync_strips_private_keys(self, tmp_path):
    1:         store = make_store(tmp_path)
    1:         store.create_collection_key("k")
    2:         source = store.add_collection_source(
    1:             "k", "arxiv", title="paper",
    1:             config={"url": "https://arxiv.org/abs/1"},
    1:             update_command="sync", delete_command="del",
               )
    1:         source["_sync_branches"] = ["main"]
    1:         adapter = ConcreteAdapter(source, store)
    1:         result = adapter.sync()
    1:         assert result["test"] is True
               # Check the persisted source doesn't have private keys
    1:         metadata = store.get_collection_metadata("k")
    2:         for s in metadata["sources"]:
    1:             assert "_sync_branches" not in s
       
       
