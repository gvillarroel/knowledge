    2:         class FakeResp:
    1:             text = "<html><title>Example</title><p>Hello World</p></html>"
    1:             headers = {"Content-Type": "text/html"}
    2:             def raise_for_status(self): pass
    1:             def json(self): return {}
       
    2:         monkeypatch.setattr("knowledge.sources.crawl4ai_site.requests.get", lambda *a, **kw: FakeResp())
