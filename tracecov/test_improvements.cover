    1:     def test_config_yaml_updated_on_reinitialize(self, tmp_path):
    1:         store = make_store(tmp_path)
               # Mutate config to trigger update path
    1:         config = yaml.safe_load(store.config_path.read_text(encoding="utf-8"))
    1:         config["paths"]["exports"] = "old"
    1:         store.config_path.write_text(yaml.safe_dump(config), encoding="utf-8")
    1:         store.initialize()
    1:         updated = yaml.safe_load(store.config_path.read_text(encoding="utf-8"))
    1:         assert updated["paths"]["exports"] == "exports"
       
    1:     def test_cleanup_orphan_source_dirs_removes_raw_library(self, tmp_path):
    1:         store = make_store(tmp_path)
    1:         store.create_collection_key("k1")
    1:         key_dir = store.key_dir("k1")
    1:         (key_dir / "raw").mkdir()
    1:         (key_dir / "library").mkdir()
    1:         result = store.cleanup_orphan_source_dirs("k1")
    1:         assert result["removed"] >= 2
    1:         assert not (key_dir / "raw").exists()
    1:         assert not (key_dir / "library").exists()
       
       
