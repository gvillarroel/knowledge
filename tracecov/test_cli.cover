    3: def test_search_confluence_queries_live_api(tmp_path: Path, capsys, monkeypatch: pytest.MonkeyPatch) -> None:
    1:     import knowledge.sources.confluence as confluence_module
       
    1:     assert main(["--store", str(tmp_path), "add", "key", "alpha"]) == 0
    4:     assert (
    4:         main(
    2:             [
    1:                 "--store",
    1:                 str(tmp_path),
    1:                 "add",
    1:                 "confluence",
    1:                 "--space",
    1:                 "ENG",
    1:                 "--key",
    1:                 "alpha",
    1:                 "--base-url",
    1:                 "https://conf.example.com",
    1:                 "--username",
    1:                 "user@example.com",
    1:                 "--token",
    1:                 "secret",
                   ]
               )
    2:         == 0
           )
       
    2:     class StubResponse:
    1:         def raise_for_status(self) -> None:
    1:             return None
       
    1:         def json(self) -> dict[str, object]:
    1:             return {
    2:                 "results": [
    1:                     {
    1:                         "title": "Incident Postmortem",
    1:                         "content": {"id": "123"},
                           }
                       ],
    1:                 "_links": {"next": "/wiki/rest/api/search?cursor=abc"},
                   }
       
    1:     def fake_get(url: str, *, headers: dict[str, str], params: dict[str, object], auth: tuple[str, str], timeout: int) -> StubResponse:
    1:         assert url == "https://conf.example.com/wiki/rest/api/search"
    1:         assert headers["Accept"] == "application/json"
    1:         assert params == {
    1:             "cql": 'text ~ "incident postmortem" AND space = "ENG"',
    1:             "limit": 25,
               }
    1:         assert auth == ("user@example.com", "secret")
    1:         assert timeout == 60
    1:         return StubResponse()
       
    1:     monkeypatch.setattr(confluence_module.requests, "get", fake_get)
       
    1:     assert main(["--store", str(tmp_path), "search", "confluence", "incident postmortem"]) == 0
    1:     output = capsys.readouterr().out
    1:     assert '"query": "incident postmortem"' in output
    1:     assert '"cql": "text ~ \\"incident postmortem\\" AND space = \\"ENG\\""' in output
    1:     assert '"space": "ENG"' in output
    1:     assert '"next_cursor": "abc"' in output
    1:     assert '"title": "Incident Postmortem"' in output
       
       
