    3: def test_export_generates_frontmatter_and_zip_archive(tmp_path: Path, capsys) -> None:
    1:     assert main(["--store", str(tmp_path), "add", "key", "sample"]) == 0
    1:     assert main(["--store", str(tmp_path), "add", "arxiv", "https://arxiv.org/abs/1706.03762", "--key", "sample"]) == 0
       
    1:     raw_file = tmp_path / "sample" / "arxiv" / "arxiv-1706.03762" / "paper.txt"
    1:     raw_file.parent.mkdir(parents=True, exist_ok=True)
    1:     raw_file.write_text("Attention Is All You Need\n", encoding="utf-8")
       
    1:     capsys.readouterr()
    1:     assert main(["--store", str(tmp_path), "export", "--key", "sample"]) == 0
    1:     output = json.loads(capsys.readouterr().out)
    1:     archive_path = Path(output["archive"])
    1:     assert archive_path.exists()
       
    1:     exported = (
    1:         tmp_path / "sample" / "arxiv" / "arxiv-1706.03762" / "paper.md"
    1:     ).read_text(encoding="utf-8")
    1:     assert exported.startswith("---\n")
    1:     assert "knowledge_key: sample" in exported
    1:     assert "source_id: arxiv-1706.03762" in exported
       
    2:     with ZipFile(archive_path) as archive:
    1:         assert "sample/metadata.yaml" in archive.namelist()
       
       
    3: def test_import_merges_metadata_from_archive(tmp_path: Path) -> None:
    1:     source_store = tmp_path / "source-store"
    1:     target_store = tmp_path / "target-store"
       
    1:     assert main(["--store", str(source_store), "add", "key", "docs"]) == 0
    1:     assert main(["--store", str(source_store), "add", "confluence", "--space", "ENG", "--key", "docs"]) == 0
    1:     assert main(["--store", str(source_store), "export", "--key", "docs"]) == 0
       
    1:     exports = sorted((source_store / "exports").glob("*.zip"))
    1:     archive = exports[-1]
       
    1:     assert main(["--store", str(target_store), "add", "key", "docs"]) == 0
    1:     assert main(["--store", str(target_store), "add", "arxiv", "https://arxiv.org/abs/1706.03762", "--key", "docs"]) == 0
    1:     assert main(["--store", str(target_store), "import", str(archive)]) == 0
       
    1:     metadata = yaml.safe_load((target_store / "docs" / "metadata.yaml").read_text(encoding="utf-8"))
    3:     source_ids = {source["id"] for source in metadata["sources"]}
    1:     assert "confluence-eng" in source_ids
    1:     assert "arxiv-1706.03762" in source_ids
       
       
