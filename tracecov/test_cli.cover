    3: def test_add_confluence_reads_credentials_from_dotenv(tmp_path: Path, monkeypatch: pytest.MonkeyPatch) -> None:
    1:     monkeypatch.delenv("CONFLUENCE_BASE_URL", raising=False)
    1:     monkeypatch.delenv("CONFLUENCE_USERNAME", raising=False)
    1:     monkeypatch.delenv("CONFLUENCE_TOKEN", raising=False)
    1:     env_path = tmp_path / ".env"
    2:     env_path.write_text(
    3:         "\n".join(
    1:             [
                       "CONFLUENCE_BASE_URL=https://example.atlassian.net",
                       "CONFLUENCE_USERNAME=tester@example.com",
                       "CONFLUENCE_TOKEN=secret-token",
                   ]
               )
    1:         + "\n",
    1:         encoding="utf-8",
           )
    1:     monkeypatch.chdir(tmp_path)
       
    1:     assert main(["--store", str(tmp_path / "store"), "add", "key", "research"]) == 0
    4:     assert (
    4:         main(
    2:             [
    1:                 "--store",
    1:                 str(tmp_path / "store"),
    1:                 "add",
    1:                 "confluence",
    1:                 "--space",
    1:                 "ENG",
    1:                 "--key",
    1:                 "research",
                   ]
               )
    2:         == 0
           )
       
    1:     metadata = yaml.safe_load((tmp_path / "store" / "research" / "metadata.yaml").read_text(encoding="utf-8"))
    1:     config = metadata["sources"][0]["config"]
    1:     assert config["base_url"] == "https://example.atlassian.net"
    1:     assert config["username"] == "$env:CONFLUENCE_USERNAME"
    1:     assert config["token"] == "$env:CONFLUENCE_TOKEN"
       
       
