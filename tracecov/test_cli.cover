    3: def test_init_creates_store(tmp_path: Path) -> None:
    1:     assert main(["--store", str(tmp_path), "init"]) == 0
    1:     assert (tmp_path / "config.yaml").exists()
    1:     assert (tmp_path / "keys.yaml").exists()
    1:     assert (tmp_path / "exports").exists()
       
       
    3: def test_add_key_creates_metadata_and_directories(tmp_path: Path) -> None:
    1:     assert main(["--store", str(tmp_path), "add", "key", "product-docs"]) == 0
       
    1:     metadata = yaml.safe_load((tmp_path / "product-docs" / "metadata.yaml").read_text(encoding="utf-8"))
    1:     assert metadata["name"] == "product-docs"
    1:     assert metadata["commands"]["sync"] == "know sync --key product-docs"
    1:     assert metadata["commands"]["export"] == "know export --key product-docs"
    1:     assert not (tmp_path / "product-docs" / "raw").exists()
    1:     assert not (tmp_path / "product-docs" / "library").exists()
    1:     assert not (tmp_path / "product-docs" / "cache").exists()
       
       
    3: def test_list_keys_returns_created_keys(tmp_path: Path, capsys) -> None:
