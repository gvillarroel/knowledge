                     nodes {
                       body
                       createdAt
                       author { login }
                     }
                   }
                 }
               }
             }
           }
           """
    4:     response = requests.post(
    2:         "https://api.github.com/graphql",
    2:         headers=_headers(token),
    2:         json={
    2:             "query": query,
    2:             "variables": {"owner": owner, "repo": repo, "first": per_page},
               },
    2:         timeout=30,
           )
    2:     response.raise_for_status()
    2:     data = response.json()
    2:     repo_data = (data.get("data") or {}).get("repository") or {}
    2:     discussions = (repo_data.get("discussions") or {}).get("nodes") or []
    2:     return discussions
       
       
