       # ── Activity helpers ─────────────────────────────────────────────────────
       
    4: def list_repo_activity(
>>>>>>     token: str,
>>>>>>     owner: str,
>>>>>>     repo: str,
           *,
    1:     state: str = "open",
    1:     per_page: int = 30,
    1:     include_discussions: bool = True,
>>>>>> ) -> list[dict[str, Any]]:
           """Return a unified list of issues, PRs, and discussions for a repo.
       
           Each item includes a ``kind`` field: ``issue``, ``pull_request``, or
           ``discussion``.
           """
    2:     items: list[dict[str, Any]] = []
       
           # Issues (includes PRs on GitHub API)
    2:     raw_issues = list_repo_issues(token, owner, repo, state=state, per_page=per_page)
    5:     for issue in raw_issues:
    3:         kind = "pull_request" if issue.get("pull_request") else "issue"
    6:         items.append({
    3:             "kind": kind,
    3:             "number": issue["number"],
    3:             "title": issue.get("title", ""),
    3:             "state": issue.get("state", "open"),
    3:             "user": (issue.get("user") or {}).get("login", ""),
    3:             "created_at": issue.get("created_at", ""),
    3:             "updated_at": issue.get("updated_at", ""),
    3:             "body": issue.get("body") or "",
    3:             "labels": [l.get("name", "") for l in issue.get("labels", [])],
    3:             "url": issue.get("html_url", ""),
    3:             "comments_count": issue.get("comments", 0),
