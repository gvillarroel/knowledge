    2:             for disc in discussions:
    2:                 items.append({
    1:                     "kind": "discussion",
    1:                     "number": disc.get("number", 0),
    1:                     "title": disc.get("title", ""),
    1:                     "state": "open",
    1:                     "user": (disc.get("author") or {}).get("login", ""),
    1:                     "created_at": disc.get("createdAt", ""),
    1:                     "updated_at": disc.get("updatedAt", ""),
    1:                     "body": disc.get("body") or "",
    1:                     "labels": [],
    1:                     "url": disc.get("url", ""),
    1:                     "comments_count": len((disc.get("comments") or {}).get("nodes") or []),
    1:                     "category": (disc.get("category") or {}).get("name", ""),
    1:                     "_discussion_comments": (disc.get("comments") or {}).get("nodes") or [],
                       })
    1:         except Exception:
    1:             pass  # Discussions API may not be available for all repos
       
    2:     return items
       
       
