    4:                 "published": _text(entry, "atom:published"),
    4:                 "updated": _text(entry, "atom:updated"),
    8:                 "authors": [_text(author, "atom:name") for author in entry.findall("atom:author", ATOM_NAMESPACE)],
    8:                 "categories": [category.get("term") for category in entry.findall("atom:category", ATOM_NAMESPACE)],
    8:                 "primary_category": next(
