    1: def _parse_arxiv_feed(payload: str) -> dict[str, object]:
    4:     root = ElementTree.fromstring(payload)
    4:     entries: list[dict[str, object]] = []
    8:     for entry in root.findall("atom:entry", ATOM_NAMESPACE):
    8:         links = {
    8:             link.get("title") or link.get("rel") or "related": link.get("href")
   16:             for link in entry.findall("atom:link", ATOM_NAMESPACE)
    8:             if link.get("href")
               }
