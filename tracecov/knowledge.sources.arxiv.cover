                   }
               )
       
    4:     return {
    4:         "total_results": _int_text(root, "opensearch:totalResults"),
    4:         "start_index": _int_text(root, "opensearch:startIndex"),
    4:         "items_per_page": _int_text(root, "opensearch:itemsPerPage"),
    4:         "entries": entries,
           }
       
       
    1: def _text(element: ElementTree.Element, selector: str) -> str | None:
   36:     node = element.find(selector, ATOM_NAMESPACE)
   36:     if node is None or node.text is None:
    3:         return None
   33:     return " ".join(node.text.split())
       
       
    1: def _int_text(element: ElementTree.Element, selector: str) -> int:
   12:     value = _text(element, selector)
   12:     return int(value) if value is not None else 0
