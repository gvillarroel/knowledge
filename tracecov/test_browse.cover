    1:         assert _extract_frontmatter_field(text, "author") == "Alice"
    1:         assert _extract_frontmatter_field(text, "missing") is None
       
    1:     def test_extract_frontmatter_field_no_frontmatter(self):
    1:         assert _extract_frontmatter_field("No frontmatter", "title") is None
       
       
