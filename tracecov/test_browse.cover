    2: class TestJiraBrowseFormatters:
    1:     def test_television_synced(self):
    1:         issues = [
    1:             {"key": "PROJ-1", "summary": "First", "status": "Done", "synced": True},
    1:             {"key": "PROJ-2", "summary": "Second", "status": "Open", "synced": False},
               ]
    1:         out = format_jira_browse_television(issues)
    1:         clean = _clean(out)
    1:         assert "● PROJ-1" in clean
    1:         assert "○ PROJ-2" in clean
    1:         assert "First" in clean
    1:         assert "Second" in clean
       
    1:     def test_television_empty(self):
    1:         assert format_jira_browse_television([]) == ""
       
    1:     def test_preview_synced(self):
    1:         issues = [{"key": "X-1", "summary": "Bug", "synced": True, "status": "Done"}]
    1:         out = format_jira_browse_preview(issues, None)
    1:         assert "✅ Yes" in out
    1:         assert "X-1" in out
       
    1:     def test_preview_not_synced(self):
    1:         issues = [{"key": "X-2", "summary": "Task", "synced": False, "status": "Open"}]
    1:         out = format_jira_browse_preview(issues, None)
    1:         assert "❌ No" in out
       
    1:     def test_preview_no_match(self):
    1:         out = format_jira_browse_preview([], "something")
    1:         assert "No issue" in out
       
    1:     def test_preview_select_by_key(self):
    1:         issues = [
    1:             {"key": "A-1", "summary": "First", "synced": True},
    1:             {"key": "A-2", "summary": "Second", "synced": False},
               ]
    1:         out = format_jira_browse_preview(issues, "○ A-2 | Second | Open")
    1:         assert "A-2" in out
       
       
