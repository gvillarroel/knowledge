    2: class TestHelpers:
    1:     def test_strip_ansi(self):
    1:         assert _strip_ansi("\033[32mhello\033[0m") == "hello"
       
    1:     def test_repo_name_from_url(self):
    1:         assert _repo_name_from_url("https://github.com/owner/repo.git") == "owner/repo"
    1:         assert _repo_name_from_url("https://github.com/owner/repo") == "owner/repo"
    1:         assert _repo_name_from_url("not-a-url") is None
       
    1:     def test_parse_owner_repo(self):
    1:         assert _parse_owner_repo("owner/repo") == ("owner", "repo")
    1:         assert _parse_owner_repo("https://github.com/owner/repo") == ("owner", "repo")
    1:         assert _parse_owner_repo("invalid") == ("", "")
       
    1:     def test_strip_yaml_frontmatter(self):
    1:         text = "---\ntitle: Hello\n---\n\nBody content"
    1:         assert "Body content" in _strip_yaml_frontmatter(text)
    1:         assert "title" not in _strip_yaml_frontmatter(text)
       
    1:     def test_strip_yaml_frontmatter_no_frontmatter(self):
    1:         text = "Just plain text"
    1:         assert _strip_yaml_frontmatter(text) == text
       
    1:     def test_extract_frontmatter_field(self):
