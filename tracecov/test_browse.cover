    2: class TestConfluenceSpacesFormatters:
    1:     """Tests for Confluence spaces television formatters."""
       
    1:     def test_format_television(self):
    1:         from knowledge.browse_tv import format_confluence_spaces_television
    1:         spaces = [
    1:             {"key": "DEV", "name": "Development", "type": "global"},
    1:             {"key": "OPS", "name": "Operations", "type": "personal"},
               ]
    1:         result = format_confluence_spaces_television(spaces)
    1:         clean = _strip_ansi(result)
    1:         assert "DEV" in clean
    1:         assert "Development" in clean
    1:         assert "OPS" in clean
       
    1:     def test_format_preview(self):
    1:         from knowledge.browse_tv import format_confluence_spaces_preview
    2:         spaces = [{"key": "DEV", "name": "Development", "type": "global",
    1:                     "web_url": "https://x.atlassian.net/wiki/spaces/DEV", "description": "A dev space"}]
    1:         result = format_confluence_spaces_preview(spaces, "DEV | Development")
    1:         assert "Development" in result
    1:         assert "A dev space" in result
       
    1:     def test_format_preview_empty(self):
    1:         from knowledge.browse_tv import format_confluence_spaces_preview
    1:         result = format_confluence_spaces_preview([], None)
    1:         assert "No space matched" in result
       
       
