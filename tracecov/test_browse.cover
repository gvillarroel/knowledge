       # ── Helpers for new tests ────────────────────────────────────────────────
       
       
    1: def _add_confluence_source(store: KnowledgeStore) -> None:
           """Register a Confluence source in the test store."""
    5:     store.create_collection_key("testkey")
   10:     store.add_collection_source(
    5:         key_name="testkey",
    5:         source_type="confluence",
    5:         title="Dev Space",
    5:         config={
    5:             "space": "DEV",
    5:             "base_url": "https://example.atlassian.net",
    5:             "username": "$env:CONFLUENCE_USER",
    5:             "token": "$env:CONFLUENCE_TOKEN",
               },
    5:         update_command="know sync confluence --space DEV --key testkey",
    5:         delete_command="know del --key testkey <id>",
           )
       
       
    1: def _add_jira_source(store: KnowledgeStore) -> None:
           """Register a Jira source in the test store."""
    2:     store.create_collection_key("testkey")
    4:     store.add_collection_source(
    2:         key_name="testkey",
