           )
    1:     assert result["files"] == 1
    1:     assert "title: 'Harness engineering: leveraging Codex in an agent-first world'" in exported
    1:     assert "url: https://openai.com/index/harness-engineering/" in exported
    1:     assert "source_metadata:" in exported
    1:     assert not (store.source_library_dir(source) / "pages.json.md").exists()
