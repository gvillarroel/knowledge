    1:     synced_ids: list[str] = []
       
    2:     class StubAdapter:
    1:         def __init__(self, source: dict, _store: KnowledgeStore) -> None:
    1:             self.source = source
       
    1:         def sync(self) -> dict[str, str]:
    1:             synced_ids.append(self.source["id"])
    1:             return {"source": self.source["id"]}
       
    2:     monkeypatch.setattr(commands, "create_source_adapter", lambda source, _store: StubAdapter(source, store))
       
    2:     payload = commands.cmd_sync(
