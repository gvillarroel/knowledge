    3: def test_television_sync_writes_channel_bundle(tmp_path: Path) -> None:
    1:     store = make_store(tmp_path)
    1:     store.create_collection_key("automation")
    2:     source = store.add_collection_source(
    1:         "automation",
    1:         "television",
    1:         source_id="television-knowledge-sources",
    1:         title="knowledge-sources",
    1:         config={
    1:             "channel": "knowledge-sources",
    1:             "description": "Browse registered sources",
    1:             "source_command": "know list sources --key automation --json",
    1:             "preview_command": "know export --key automation",
    1:             "action_command": "know sync --key automation",
               },
    1:         update_command="know sync television knowledge-sources --key automation",
    1:         delete_command="know del --key automation television-knowledge-sources",
           )
       
    1:     payload = TelevisionSource(source, store).sync()
       
    1:     channel_file = store.source_raw_dir(source) / "knowledge-sources.toml"
    1:     manifest_file = store.source_raw_dir(source) / "commands.json"
    1:     readme_file = store.source_raw_dir(source) / "README.md"
    1:     manifest = json.loads(manifest_file.read_text(encoding="utf-8"))
       
    1:     assert payload["files"] == 3
    1:     assert channel_file.exists()
    1:     assert manifest_file.exists()
    1:     assert readme_file.exists()
    1:     channel_text = channel_file.read_text(encoding="utf-8")
    1:     assert 'name = "knowledge-sources"' in channel_text
    1:     assert 'command = "know list sources --key automation --json"' in channel_text
