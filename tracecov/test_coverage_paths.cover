    1: def test_find_selected_source():
    1:     from knowledge.commands import _find_selected_source
       
    1:     sources = [
    1:         {"id": "a", "type": "confluence"},
    1:         {"id": "b", "type": "jira"},
           ]
    1:     assert _find_selected_source(sources, "b | jira")["id"] == "b"
    1:     assert _find_selected_source(sources, None)["id"] == "a"
    1:     assert _find_selected_source(sources, "nonexistent")["id"] == "a"
    1:     assert _find_selected_source([], "anything") is None
