    3: def test_confluence_storage_to_markdown_renders_basic_blocks() -> None:
    1:     payload = (
    1:         "<h1>Overview</h1>"
               "<p>Hello <strong>world</strong> and <a href=\"https://example.com\">link</a>.</p>"
               "<ul><li>First</li><li>Second</li></ul>"
               "<pre><code>print('x')</code></pre>"
           )
       
    1:     rendered = confluence_storage_to_markdown(payload)
       
    1:     assert "# Overview" in rendered
    1:     assert "Hello **world** and [link](https://example.com)." in rendered
    1:     assert "- First" in rendered
    1:     assert "- Second" in rendered
    1:     assert "```" in rendered
    1:     assert "print('x')" in rendered
       
       
    3: def test_confluence_storage_to_markdown_covers_misc_blocks() -> None:
    1:     payload = (
    1:         "<blockquote><p>Quoted</p></blockquote>"
               "<p><em>soft</em><br/><code>x</code></p>"
               "<hr/>"
               "<ac:structured-macro ac:name=\"code\"><ac:plain-text-body>const x = 1;</ac:plain-text-body></ac:structured-macro>"
           )
       
    1:     rendered = confluence_storage_to_markdown(payload)
       
    1:     assert "> Quoted" in rendered
    1:     assert "*soft*" in rendered
    1:     assert "`x`" in rendered
    1:     assert "---" in rendered
    1:     assert "const x = 1;" in rendered
       
       
    3: def test_confluence_storage_to_markdown_normalizes_task_artifacts() -> None:
    1:     payload = "<p>Tasks</p><ac:task-list>\\n<ac:task>\\n<ac:task-id>1</ac:task-id>\\n<ac:task-status>incomplete</ac:task-status>\\nEscribe tu tarea aquí.\\n\\n</ac:task></ac:task-list>"
       
    1:     rendered = confluence_storage_to_markdown(payload)
       
    1:     assert "1\nincomplete" not in rendered
    1:     assert "- [ ] Escribe tu tarea aquí." in rendered
       
       
