    3: def test_export_arxiv_only_writes_single_paper_document(tmp_path: Path) -> None:
    1:     store = make_store(tmp_path)
    1:     store.create_collection_key("papers")
    2:     source = store.add_collection_source(
    1:         "papers",
    1:         "arxiv",
    1:         title="https://arxiv.org/abs/1706.03762",
    1:         config={"url": "https://arxiv.org/abs/1706.03762"},
    1:         update_command="sync",
    1:         delete_command="del",
           )
    1:     raw_dir = store.source_raw_dir(source)
    2:     raw_dir.joinpath("paper.xml").write_text(
    1:         """<?xml version="1.0" encoding="utf-8"?>
       <feed xmlns="http://www.w3.org/2005/Atom">
         <entry>
           <id>http://arxiv.org/abs/1706.03762v7</id>
           <updated>2023-08-02T17:54:18Z</updated>
           <published>2017-06-12T17:57:25Z</published>
           <title>Attention Is All You Need</title>
           <summary>Transformer paper summary.</summary>
           <author><name>Ashish Vaswani</name></author>
           <category term="cs.CL" />
           <link rel="alternate" href="http://arxiv.org/abs/1706.03762v7" />
           <link title="pdf" href="http://arxiv.org/pdf/1706.03762v7" />
         </entry>
       </feed>
       """,
    1:         encoding="utf-8",
           )
    1:     raw_dir.joinpath("source-url.txt").write_text("https://arxiv.org/abs/1706.03762\n", encoding="utf-8")
       
    1:     result = export_source(store, source)
       
    1:     exported = (store.source_library_dir(source) / "paper.md").read_text(encoding="utf-8")
    1:     assert result["files"] == 1
    1:     assert (store.source_library_dir(source) / "paper.md").exists()
    1:     assert not (store.source_library_dir(source) / "source-url.txt.md").exists()
    1:     assert "paper_id: '1706.03762'" in exported or "paper_id: 1706.03762" in exported
    1:     assert "source_url: https://arxiv.org/abs/1706.03762" in exported
    1:     assert "# Attention Is All You Need" in exported
    1:     assert "## Summary" in exported
       
       
    3: def test_export_site_only_writes_page_documents_with_sidecar_metadata(tmp_path: Path) -> None:
