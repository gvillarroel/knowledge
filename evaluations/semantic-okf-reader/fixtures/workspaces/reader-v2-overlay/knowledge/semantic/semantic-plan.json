  "rules": [
    {
      "basis": {
        "kind": "operational-policy",
        "references": [
          "FORTY-DOC-1"
        ]
      },
      "datatype": "xsd:string",
      "max_count": 1,
      "message": "Each accepted document must have one non-empty category.",
      "min_count": 1,
      "name": "DocumentCategoryRule",
      "path": "category",
      "pattern": ".+",
      "target_class": "Document"
    },
    {
      "basis": {
        "kind": "operational-policy",
        "references": [
          "FORTY-PERSON-1"
        ]
      },
      "datatype": "xsd:string",
      "max_count": 1,
      "message": "Each accepted person must have one non-empty role.",
      "min_count": 1,
      "name": "PersonRoleRule",
      "path": "role",
      "pattern": ".+",
      "target_class": "Person"
    },
    {
      "basis": {
        "kind": "operational-policy",
        "references": [
          "FORTY-PROJECT-1"
        ]
      },
      "datatype": "xsd:string",
      "max_count": 1,
      "message": "Each accepted project must have one non-empty status.",
      "min_count": 1,
      "name": "ProjectStatusRule",
      "path": "status",
      "pattern": ".+",
      "target_class": "Project"
    },
    {
      "basis": {
        "kind": "operational-policy",
        "references": [
          "FORTY-PROJECT-2"
        ]
      },
      "class": "Person",
      "max_count": 1,
      "message": "Each accepted project must identify one accepted person owner.",
      "min_count": 1,
      "name": "ProjectOwnerRule",
      "node_kind": "IRI",
      "path": "owner",
      "target_class": "Project"
    },
    {
      "basis": {
        "kind": "evidence",
        "references": [
          "FORTY-VOCAB-1"
        ]
      },
      "datatype": "xsd:string",
      "message": "Each accepted vocabulary resource must have a preferred label.",
      "min_count": 1,
      "name": "VocabularyLabelRule",
      "path": "prefLabel",
      "pattern": ".+",
      "target_class": "VocabularyResource"
    }
  ],
