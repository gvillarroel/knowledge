        {
          "text": "Integration gates observed in this tenant",
          "type": "text"
        }
      ],
      "type": "heading"
    },
    {
      "content": [
        {
          "content": [
            {
              "content": [
                {
                  "text": "Jira Activities reported that the account has no accessible Jira sites.",
                  "type": "text"
                }
              ],
              "type": "paragraph"
            }
          ],
          "type": "listItem"
        },
        {
          "content": [
            {
              "content": [
                {
                  "text": "Jira Charts requested an administrator-managed Confluence-to-Jira connection.",
                  "type": "text"
                }
              ],
              "type": "paragraph"
            }
          ],
          "type": "listItem"
        },
        {
          "content": [
            {
              "content": [
                {
                  "text": "Assets reported that the account does not have access to the requested content.",
                  "type": "text"
                }
              ],
              "type": "paragraph"
            }
          ],
          "type": "listItem"
        },
        {
          "content": [
            {
              "content": [
                {
                  "text": "Activity Stream, Team Calendars, Jira Timeline, Word, and PowerPoint were not offered as insertable core elements in the current editor catalog.",
                  "type": "text"
                }
              ],
              "type": "paragraph"
            }
          ],
          "type": "listItem"
        }
      ],
      "type": "bulletList"
    }
