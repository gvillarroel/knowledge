{"bioc_sha256":"04dd962ae24c5decf35dbecf9677753eaa7128b5fca63d8fb88f4fdcfcea518f","claim_kind":"methodology","claim_origin":"manual-review:bioc-passage","confidence":"high","evidence_locator":"sources/markdown/PMC5047791.md#BioC-passage-0005","evidence_text_sha256":"0da90cbaacb0189ff6f99982cbea4423acf2bf032f0f8644c5912e43beceb626","id":"claim-pmc5047791-001","interpretation":"One hundred Latina adolescents replaced their usual personal-care products for three days with products labeled free of the target chemicals and provided paired pre-intervention and post-intervention urine samples.","object_term_iri":"https://example.org/endocrine-hygiene/resource/analysis-vocabulary/dimension-methodology","paper_iri":"https://example.org/endocrine-hygiene/resource/paper-pmc5047791/sources%2Fmarkdown%2FPMC5047791","review_state":"reviewed","subject_term_iri":"https://example.org/endocrine-hygiene/resource/analysis-vocabulary/method-pmc5047791","title":"PMC5047791 methodology claim 001"}
