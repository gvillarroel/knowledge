  "rules": [
    {
      "basis": {
        "kind": "evidence",
        "references": [
          "END-HYG-STUDY-1"
        ]
      },
      "datatype": "xsd:string",
      "max_count": 1,
      "message": "Every paper must retain its canonical PMCID.",
      "min_count": 1,
      "name": "PaperIdentifierRule",
      "path": "paperId",
      "pattern": "^PMC[1-9][0-9]*$",
      "target_class": "Paper"
    },
    {
      "basis": {
        "kind": "evidence",
        "references": [
          "END-HYG-STUDY-1"
        ]
      },
      "datatype": "xsd:string",
      "max_count": 1,
      "message": "Every paper must retain its accepted raw BioC digest.",
      "min_count": 1,
      "name": "PaperDigestRule",
      "path": "rawBiocSha256",
      "pattern": "^[0-9a-f]{64}$",
      "target_class": "Paper"
    },
    {
      "basis": {
        "kind": "evidence",
        "references": [
          "END-HYG-STUDY-1"
        ]
      },
      "datatype": "xsd:string",
      "max_count": 1,
      "message": "Every analysis term must have a label.",
      "min_count": 1,
      "name": "TermLabelRule",
      "path": "termLabel",
      "pattern": ".+",
      "target_class": "AnalysisTerm"
    },
    {
      "basis": {
        "kind": "evidence",
        "references": [
          "END-HYG-STUDY-1"
        ]
      },
      "class": "Paper",
      "max_count": 1,
      "message": "Every claim must identify its source paper.",
      "min_count": 1,
      "name": "ClaimPaperRule",
      "node_kind": "IRI",
      "path": "aboutPaper",
      "target_class": "PaperSemanticClaim"
    },
    {
      "basis": {
        "kind": "evidence",
        "references": [
          "END-HYG-STUDY-1"
        ]
      },
      "class": "AnalysisTerm",
      "max_count": 1,
      "message": "Every claim must identify its paper-specific study design.",
      "min_count": 1,
      "name": "ClaimSubjectRule",
      "node_kind": "IRI",
      "path": "subjectTerm",
      "target_class": "PaperSemanticClaim"
    },
    {
      "basis": {
        "kind": "evidence",
        "references": [
          "END-HYG-STUDY-1"
        ]
      },
      "class": "AnalysisTerm",
      "max_count": 1,
      "message": "Every claim must identify one analysis dimension.",
      "min_count": 1,
      "name": "ClaimDimensionRule",
      "node_kind": "IRI",
      "path": "objectTerm",
      "target_class": "PaperSemanticClaim"
    },
    {
      "basis": {
        "kind": "evidence",
        "references": [
          "END-HYG-STUDY-1"
        ]
      },
      "datatype": "xsd:string",
      "max_count": 1,
      "message": "Every claim must use one reviewed claim kind.",
      "min_count": 1,
      "name": "ClaimKindRule",
      "path": "claimKind",
      "pattern": "^(methodology|exposure-association|intervention-effect|hormonal-mechanism|health-outcome|product-content|risk-assessment|disparity|limitation|null-result|comparison)$",
      "target_class": "PaperSemanticClaim"
    },
    {
      "basis": {
        "kind": "evidence",
        "references": [
          "END-HYG-STUDY-1"
        ]
      },
      "datatype": "xsd:string",
      "max_count": 1,
      "message": "Every claim must cite one exact BioC passage.",
      "min_count": 1,
      "name": "ClaimEvidenceRule",
      "path": "evidenceLocator",
      "pattern": "^sources/markdown/PMC[1-9][0-9]*\\.md#BioC-passage-[0-9]{4}$",
      "target_class": "PaperSemanticClaim"
    },
    {
      "basis": {
        "kind": "evidence",
        "references": [
          "END-HYG-STUDY-1"
        ]
      },
      "datatype": "xsd:string",
      "max_count": 1,
      "message": "Every accepted claim must be reviewed.",
      "min_count": 1,
      "name": "ClaimReviewRule",
      "path": "reviewState",
      "pattern": "^reviewed$",
      "target_class": "PaperSemanticClaim"
    }
  ],
